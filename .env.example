# ─── Database ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cliptale
DB_USER=cliptale
DB_PASSWORD=

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Object Storage (S3 / Cloudflare R2) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=cliptale-assets
S3_ENDPOINT=                    # Leave blank for AWS; set for R2 (https://<account>.r2.cloudflarestorage.com)
S3_REGION=us-east-1

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── OpenAI (Whisper transcription) ─────────────────────────────────────────
OPENAI_API_KEY=

# ─── API server ──────────────────────────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Web editor ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
