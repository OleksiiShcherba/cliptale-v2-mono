# ─── Database ───────────────────────────────────────────────────────────────
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_NAME=cliptale
APP_DB_USER=cliptale
APP_DB_PASSWORD=cliptale

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
APP_REDIS_URL=redis://localhost:6379

# ─── Object Storage (S3 / Cloudflare R2) ────────────────────────────────────
APP_S3_ACCESS_KEY_ID=
APP_S3_SECRET_ACCESS_KEY=
APP_S3_BUCKET=cliptale-assets
# APP_S3_ENDPOINT=                 # Leave blank for AWS; set for R2: https://<account>.r2.cloudflarestorage.com
APP_S3_ENDPOINT=
APP_S3_REGION=us-east-1

# ─── Auth ────────────────────────────────────────────────────────────────────
APP_JWT_SECRET=local-dev-jwt-secret-change-in-production-minimum-32-chars
APP_JWT_EXPIRES_IN=7d
APP_DEV_AUTH_BYPASS=true

# ─── OAuth (Google + GitHub) ────────────────────────────────────────────
APP_GOOGLE_CLIENT_ID=
APP_GOOGLE_CLIENT_SECRET=
APP_GITHUB_CLIENT_ID=
APP_GITHUB_CLIENT_SECRET=
APP_OAUTH_REDIRECT_BASE=http://localhost:3001
APP_FRONTEND_URL=http://localhost:5173

# ─── OpenAI (Whisper transcription) ─────────────────────────────────────────
APP_OPENAI_API_KEY=

# ─── fal.ai (unified AI generation backend) ─────────────────────────────────
APP_FAL_KEY=

# ─── ElevenLabs (audio generation: TTS, voice cloning, S2S, music) ──────────
APP_ELEVENLABS_API_KEY=

# ─── API server ──────────────────────────────────────────────────────────────
APP_PORT=3001
# For local dev: http://localhost:5173
# For nip.io deploy: https://15-236-162-140.nip.io  (or your public web-editor origin)
APP_CORS_ORIGIN=http://localhost:5173

# ─── Web editor ──────────────────────────────────────────────────────────────
# For local dev: http://localhost:3001
# For nip.io deploy: https://api.15-236-162-140.nip.io  (or your public API origin)
VITE_PUBLIC_API_BASE_URL=http://localhost:3001
