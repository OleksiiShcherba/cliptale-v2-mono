    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.9.0",
    "sanitize-html": "^2.12.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
